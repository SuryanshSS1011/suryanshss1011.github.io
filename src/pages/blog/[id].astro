---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Filter headings for TOC (h2 and h3 only)
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={`${post.data.title} — Suryansh Sijwali`} description={post.data.description}>
  <article>
    <header style="margin-bottom: var(--spacing-lg);">
      <h1>{post.data.title}</h1>
      <p class="text-muted text-sm">
        {formatDate(post.data.date)}
        {post.data.tags && (
          <span> · {post.data.tags.slice(0, 3).join(', ')}</span>
        )}
      </p>
    </header>

    {tocHeadings.length > 2 && (
      <nav class="toc">
        <h2>Contents</h2>
        <ul>
          {tocHeadings.map((heading) => (
            <li class={heading.depth === 3 ? 'toc-sub' : ''}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="prose">
      <Content />
    </div>

    <footer style="margin-top: var(--spacing-xl);">
      <a href="/blog">← Back to blog</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .toc {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .toc h2 {
    font-size: 0.9rem;
    margin-bottom: var(--spacing-sm);
    border: none;
    padding: 0;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li {
    margin-bottom: var(--spacing-xs);
  }

  .toc-sub {
    padding-left: var(--spacing-md);
  }

  .toc a {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .toc a:hover {
    color: var(--accent);
  }
</style>
