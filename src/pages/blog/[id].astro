---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { id: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

const wordCount = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

const postURL = new URL(`/blog/${post.id}/`, Astro.site ?? site.url).toString();
const ogImageURL = new URL("/og.png", Astro.site ?? site.url).toString();

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: postURL,
  image: ogImageURL,
  wordCount,
  keywords: post.data.tags?.join(", "),
  author: {
    "@type": "Person",
    name: site.name,
    url: site.url
  },
  publisher: {
    "@type": "Person",
    name: site.name,
    url: site.url
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postURL
  }
};
---

<BaseLayout
  title={`${post.data.title} · Suryansh Sijwali`}
  description={post.data.description}
  ogType="article"
  articleMeta={{
    publishedTime: post.data.date.toISOString(),
    tags: post.data.tags
  }}
  jsonLd={blogPostingSchema}
>
  <article>
    <header style="margin-bottom: var(--spacing-xl);">
      <h1>{post.data.title}</h1>
      <p class="text-muted text-sm" style="font-family: var(--font-display);">
        By Suryansh Sijwali · <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {wordCount > 0 && (
          <> · {readingTime} min read</>
        )}
        {post.data.tags && post.data.tags.length > 0 && (
          <span> · {post.data.tags.slice(0, 3).join(', ')}</span>
        )}
      </p>
    </header>

    {tocHeadings.length > 2 && (
      <aside class="toc" aria-label="Table of contents">
        <p class="toc-label">Contents</p>
        <ol class="toc-list">
          {tocHeadings.map((heading, i) => (
            <li class={heading.depth === 3 ? 'toc-item toc-sub' : 'toc-item'}>
              {heading.depth === 2 && (
                <span class="toc-num" aria-hidden="true">{String(tocHeadings.filter((h, j) => j <= i && h.depth === 2).length).padStart(2, '0')}</span>
              )}
              <a href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </aside>
    )}

    <div class="prose">
      <Content />
    </div>

    <footer style="margin-top: var(--spacing-2xl);">
      <a href="/blog">← Back to writing</a>
    </footer>
  </article>
</BaseLayout>

<style>
  /* TOC: editorial margin note. No card chrome, no list markers, no decimal default. */

  /* Defensive resets: kill any inherited list styling, padding, or backgrounds. */
  .toc,
  .toc * {
    background: transparent;
    border-radius: 0;
  }

  .toc {
    margin: 0 0 var(--spacing-2xl) 0;
    padding: 0 0 0 var(--spacing-md);
    border-left: 1px solid var(--border);
    background: transparent;
  }

  .toc-label {
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 var(--spacing-sm) 0;
    padding: 0;
  }

  /* Force list reset hard, in case anything else tries to add markers. */
  ol.toc-list {
    list-style: none !important;
    list-style-type: none !important;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  ol.toc-list > li.toc-item {
    list-style: none !important;
    list-style-type: none !important;
    display: grid;
    grid-template-columns: 1.75rem 1fr;
    align-items: baseline;
    column-gap: 0.5rem;
    line-height: 1.4;
    margin: 0;
    padding: 0;
  }

  ol.toc-list > li.toc-item::marker {
    content: none;
  }

  /* Sub-items (H3 under H2): collapse to a single column and indent via padding.
     Avoids reserving the hidden-number column and lets long titles wrap cleanly
     aligned to the link text's left edge. Specificity matches the base rule
     above (.toc-list > li.toc-item) by re-using the same selector chain. */
  ol.toc-list > li.toc-item.toc-sub {
    grid-template-columns: 1fr;
    padding-left: 1.25rem;
  }

  .toc-num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .toc a {
    color: var(--text-muted);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.88rem;
    line-height: 1.45;
    transition: color var(--transition), border-color var(--transition);
    border-left: 1.5px solid transparent;
    padding-left: 0.6rem;
    margin-left: -0.6rem;
  }

  .toc a:hover {
    color: var(--text-primary);
    text-decoration: none;
  }

  .toc a[data-active="true"] {
    color: var(--text-primary);
    border-left-color: var(--accent);
  }

  /* Desktop: float to the right of the prose as a sticky rail. */
  @media (min-width: 1100px) {
    .toc {
      position: sticky;
      top: var(--spacing-2xl);
      float: right;
      width: 16rem;
      margin: 0 -19rem 0 0;
      padding-left: var(--spacing-lg);
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
      scrollbar-width: thin;
    }

    ol.toc-list {
      gap: 0.55rem;
    }

    .toc a {
      font-size: 0.83rem;
    }
  }

  @media (min-width: 1280px) {
    .toc {
      width: 18rem;
      margin-right: -21rem;
    }
  }
</style>

<script>
  // Scrollspy: highlight the heading closest to the top of the viewport.
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc a[data-toc-link]');
  if (links.length > 0) {
    const headingIds = Array.from(links).map((a) => a.dataset.tocLink!).filter(Boolean);
    const headings = headingIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => !!el);

    let activeId: string | null = null;
    const setActive = (id: string | null) => {
      if (id === activeId) return;
      activeId = id;
      links.forEach((a) => {
        a.toggleAttribute('data-active', a.dataset.tocLink === id);
      });
    };

    const onScroll = () => {
      const offset = 120;
      let current: string | null = null;
      for (const h of headings) {
        const rect = h.getBoundingClientRect();
        if (rect.top - offset <= 0) current = h.id;
        else break;
      }
      setActive(current ?? headings[0]?.id ?? null);
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  }
</script>
