---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import PostListItem from '../../components/PostListItem.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Writing — Suryansh Sijwali" description="Notes on AI, software engineering, and research.">
  <SectionHeading
    eyebrow="Writing"
    title="Notes on AI, software, and research"
    description="Long-form writeups, research notes, and thoughts on the systems I build and study."
    level="h1"
  />

  <section>
    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <PostListItem post={post} />
        ))}
      </ul>
    ) : (
      <p class="text-muted">No posts yet. Check back soon.</p>
    )}
  </section>
</BaseLayout>
