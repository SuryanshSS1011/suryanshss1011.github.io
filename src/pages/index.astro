---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PostListItem from '../components/PostListItem.astro';
import { site, about, projects } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => {
    if (a.data.pinBottom !== b.data.pinBottom) {
      return a.data.pinBottom ? 1 : -1;
    }
    return b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 3);

// Three hand-picked flagships for the home page. Comprehensive lists live on /research and /engineering.
const flagshipTitles = [
  "Warren",
  "Scheduled Partial-Credit RL for Reliable Code Generation with Small Language Models",
  "Match Your Loss to Your Cost"
];
const flagships = flagshipTitles
  .map(t => projects.find(p => p.title === t))
  .filter((p): p is typeof projects[number] => !!p);
---

<BaseLayout
  title={`${site.name} · ${site.title}`}
  description="Suryansh Sijwali, Penn State CS. Currently building Warren. Research on Scheduled Partial-Credit RL for Reliable Code Generation with SLMs (LCTES 2026 WIP), Match Your Loss to Your Cost (CNSM 2026 submission), and LLM explanations for Java performance bugs (IEEE AITest 2025)."
>
  <section class="profile">
    <h1>{site.name}</h1>
    <p class="subtitle">{site.title}</p>
    <dl class="status">
      <div class="status-row">
        <dt>Currently working on</dt>
        <dd>{about.currently}</dd>
      </div>
      <div class="status-row">
        <dt>Recently submitted</dt>
        <dd>{about.submitted}</dd>
      </div>
      <div class="status-row">
        <dt>Upcoming</dt>
        <dd>{about.upcoming}</dd>
      </div>
    </dl>
    <div class="bio">
      {site.bioLines.map((line) => <p>{line}</p>)}
    </div>

    <div class="links">
      <a href={site.social.github} target="_blank" rel="noopener">GitHub</a>
      <a href={site.social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href={site.social.orcid} target="_blank" rel="noopener">ORCID</a>
      <a href={site.social.scholar} target="_blank" rel="noopener">Scholar</a>
      <a href={`mailto:${site.social.email}`}>Email</a>
    </div>
  </section>

  <section>
    <SectionHeading eyebrow="About" title="A little context" />
    <p style="white-space: pre-line;">{about.bio}</p>
  </section>

  <section>
    <SectionHeading eyebrow="Education" title={about.education.degree} />
    <dl class="ed-grid">
      <dt>School</dt>
      <dd>{about.education.institution} <span class="ed-tail">· {about.education.colleges.join(' · ')}</span></dd>

      <dt>Expected</dt>
      <dd>{about.education.graduation}</dd>

      <dt>Minors</dt>
      <dd>{about.education.minors.join(' · ')}</dd>
    </dl>
  </section>

  {flagships.length > 0 && (
    <section>
      <SectionHeading eyebrow="Selected work" />
      <div class="project-list">
        {flagships.map((project) => (
          <ProjectCard project={project} compact />
        ))}
      </div>
      <p class="mt-md"><a href="/research">All research →</a></p>
      <p><a href="/engineering">All engineering →</a></p>
    </section>
  )}

  <section>
    <SectionHeading eyebrow="Writing" title="Recent notes" />
    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <PostListItem post={post} showExcerpt={false} />
        ))}
      </ul>
    ) : (
      <p class="text-muted">Coming soon.</p>
    )}
    <p class="mt-md"><a href="/blog">All writing →</a></p>
  </section>
</BaseLayout>
