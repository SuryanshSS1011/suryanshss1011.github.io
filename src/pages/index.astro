---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, about, projects } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}
---

<BaseLayout title={`${site.name} — ${site.title}`}>
  <section class="profile">
    <h1>{site.name}</h1>
    <p class="subtitle">{site.title}</p>
    <p class="bio">{site.description}</p>

    <div class="links">
      <a href={site.social.github} target="_blank" rel="noopener">GitHub</a>
      <a href={site.social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href={`mailto:${site.social.email}`}>Email</a>
    </div>
  </section>

  <section>
    <h2>About</h2>
    <p style="white-space: pre-line;">{about.bio}</p>

    <div class="mt-sm" style="display: flex; flex-direction: column; gap: 0.5rem;">
      {about.roles.map((role) => (
        <div class="card">
          <p><strong>{role.title}</strong> at {role.company}</p>
          <p class="text-muted text-sm">{role.period}</p>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2>Education</h2>
    <p><strong>{about.education.degree}</strong></p>
    <p>{about.education.institution} · {about.education.graduation}</p>
    <p class="text-muted text-sm mt-sm">{about.education.colleges.join(' · ')}</p>
    <p class="text-muted text-sm">{about.education.minors.join(', ')}</p>
  </section>

  <section>
    <h2>Featured Projects and Research</h2>
    <div class="project-grid">
      {projects.slice(0, 2).map((project) => (
        <div class="card project-card">
          <h3>
            <a href={project.url} target={project.url.startsWith('/') ? '_self' : '_blank'} rel="noopener">
              {project.title}
            </a>
          </h3>
          <p>{project.description}</p>
          <div class="project-links">
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener">Code</a>
            )}
            {!project.url.startsWith('/') && (
              <a href={project.url} target="_blank" rel="noopener">Live</a>
            )}
          </div>
        </div>
      ))}
    </div>
    <p class="mt-sm"><a href="/projects">View all projects →</a></p>
  </section>

  <section>
    <h2>Recent Writing</h2>
    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
            <time>{formatDate(post.data.date)}</time>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-muted">Coming soon.</p>
    )}
    <p class="mt-sm"><a href="/blog">View all posts →</a></p>
  </section>
</BaseLayout>
