---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PostListItem from '../components/PostListItem.astro';
import { site, about, projects } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const currentResearch = projects
  .filter(p => p.category === 'research' && p.current)
  .slice(0, 2);

const pastResearch = projects
  .filter(p => p.category === 'research' && !p.current)
  .slice(0, 2);

const currentEngineering = projects
  .filter(p => p.category === 'engineering' && p.current)
  .slice(0, 2);

const pastEngineering = projects
  .filter(p => p.category === 'engineering' && !p.current)
  .slice(0, 2);
---

<BaseLayout
  title={`${site.name} · ${site.title}`}
  description="Suryansh Sijwali is an AI/ML engineer and researcher at Penn State. Work on RL for secure code generation (LCTES 2026 WIP), ML for network capacity planning, citation-grounded RAG, and LLM-based performance bug detection (IEEE AITest 2025)."
>
  <section class="profile">
    <h1>{site.name}</h1>
    <p class="subtitle">{site.title}</p>
    <dl class="status">
      <div class="status-row">
        <dt>Currently working on</dt>
        <dd>{about.currently}</dd>
      </div>
      <div class="status-row">
        <dt>Submitted</dt>
        <dd>{about.submitted}</dd>
      </div>
      <div class="status-row">
        <dt>Upcoming</dt>
        <dd>{about.upcoming}</dd>
      </div>
    </dl>
    <p class="bio">{site.description}</p>

    <div class="links">
      <a href={site.social.github} target="_blank" rel="noopener">GitHub</a>
      <a href={site.social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href={site.social.orcid} target="_blank" rel="noopener">ORCID</a>
      <a href={site.social.scholar} target="_blank" rel="noopener">Scholar</a>
      <a href={`mailto:${site.social.email}`}>Email</a>
    </div>
  </section>

  <section>
    <SectionHeading eyebrow="About" title="A little context" />
    <p style="white-space: pre-line;">{about.bio}</p>
  </section>

  <section>
    <SectionHeading eyebrow="Education" title={about.education.degree} />
    <dl class="ed-grid">
      <dt>School</dt>
      <dd>{about.education.institution} <span class="ed-tail">· {about.education.colleges.join(' · ')}</span></dd>

      <dt>Expected</dt>
      <dd>{about.education.graduation}</dd>

      <dt>Minors</dt>
      <dd>{about.education.minors.join(' · ')}</dd>
    </dl>
  </section>

  {currentResearch.length > 0 && (
    <section>
      <SectionHeading eyebrow="Research" title="In progress" />
      <div class="project-list">
        {currentResearch.map((project) => (
          <ProjectCard project={project} compact />
        ))}
      </div>
    </section>
  )}

  {pastResearch.length > 0 && (
    <section>
      <SectionHeading eyebrow="Research" title="Published" />
      <div class="project-list">
        {pastResearch.map((project) => (
          <ProjectCard project={project} compact />
        ))}
      </div>
      <p class="mt-md"><a href="/research">All research →</a></p>
    </section>
  )}

  {currentEngineering.length > 0 && (
    <section>
      <SectionHeading eyebrow="Engineering" title="Currently building" />
      <div class="project-list">
        {currentEngineering.map((project) => (
          <ProjectCard project={project} compact />
        ))}
      </div>
    </section>
  )}

  {pastEngineering.length > 0 && (
    <section>
      <SectionHeading eyebrow="Engineering" title="Past work (shipped)" />
      <div class="project-list">
        {pastEngineering.map((project) => (
          <ProjectCard project={project} compact />
        ))}
      </div>
      <p class="mt-md"><a href="/engineering">All engineering →</a></p>
    </section>
  )}

  <section>
    <SectionHeading eyebrow="Writing" title="Recent notes" />
    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <PostListItem post={post} showExcerpt={false} />
        ))}
      </ul>
    ) : (
      <p class="text-muted">Coming soon.</p>
    )}
    <p class="mt-md"><a href="/blog">All writing →</a></p>
  </section>
</BaseLayout>
