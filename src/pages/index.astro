---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PostListItem from '../components/PostListItem.astro';
import { site, about, projects } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredResearch = projects
  .filter(p => p.category === 'research' && p.current)
  .slice(0, 2);

const featuredEngineering = projects
  .filter(p => p.category === 'engineering' && p.current)
  .slice(0, 2);
---

<BaseLayout title={`${site.name} — ${site.title}`}>
  <section class="profile">
    <h1>{site.name}</h1>
    <p class="subtitle">{site.title}</p>
    <p class="bio">{site.description}</p>

    <div class="links">
      <a href={site.social.github} target="_blank" rel="noopener">GitHub</a>
      <a href={site.social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href={`mailto:${site.social.email}`}>Email</a>
    </div>
  </section>

  <section>
    <SectionHeading eyebrow="About" title="A little context" />
    <p style="white-space: pre-line;">{about.bio}</p>

    <div class="mt-sm" style="display: flex; flex-direction: column; gap: 0.5rem;">
      {about.roles.map((role) => (
        <div class="card">
          <p style="margin-bottom: 0.25rem;"><strong style="color: var(--text-primary);">{role.title}</strong> at {role.company}</p>
          <p class="text-muted text-sm" style="margin-bottom: 0;">{role.period}</p>
        </div>
      ))}
    </div>
  </section>

  <section>
    <SectionHeading eyebrow="Education" title={about.education.degree} />
    <p>{about.education.institution} · {about.education.graduation}</p>
    <p class="text-muted text-sm mt-sm">{about.education.colleges.join(' · ')}</p>
    <p class="text-muted text-sm">Minors: {about.education.minors.join(', ')}</p>
  </section>

  {featuredResearch.length > 0 && (
    <section>
      <SectionHeading eyebrow="Research" title="Featured papers and investigations" />
      <div class="project-list">
        {featuredResearch.map((project) => (
          <ProjectCard project={project} compact />
        ))}
      </div>
      <p class="mt-sm"><a href="/research">All research →</a></p>
    </section>
  )}

  {featuredEngineering.length > 0 && (
    <section>
      <SectionHeading eyebrow="Engineering" title="What I'm shipping" />
      <div class="project-list">
        {featuredEngineering.map((project) => (
          <ProjectCard project={project} compact />
        ))}
      </div>
      <p class="mt-sm"><a href="/engineering">All engineering →</a></p>
    </section>
  )}

  <section>
    <SectionHeading eyebrow="Writing" title="Recent notes" />
    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <PostListItem post={post} showExcerpt={false} />
        ))}
      </ul>
    ) : (
      <p class="text-muted">Coming soon.</p>
    )}
    <p class="mt-sm"><a href="/blog">All writing →</a></p>
  </section>
</BaseLayout>
