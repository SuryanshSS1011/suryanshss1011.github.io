---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { projects, site } from '../data/site';

const research = projects.filter(p => p.category === 'research');
const current = research.filter(p => p.current);
const past = research.filter(p => !p.current);

const author = { "@type": "Person", name: site.name, url: site.url };

const aiTestPaperSchema = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  name: "Fixing Performance Bugs Through LLM Explanations",
  author,
  isPartOf: {
    "@type": "PublicationEvent",
    name: "7th IEEE International Conference on Artificial Intelligence Testing (AITest 2025)",
    publishedBy: { "@type": "Organization", name: "IEEE" }
  },
  datePublished: "2025-07-22",
  identifier: "10.1109/AITest66680.2025.00020",
  url: "https://doi.org/10.1109/AITest66680.2025.00020"
};

const lctesPaperSchema = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  name: "Scheduled Partial-Credit RL for Reliable Code Generation with Small Language Models",
  alternateName: "SecureCodeRL",
  author,
  isPartOf: {
    "@type": "PublicationEvent",
    name: "27th ACM SIGPLAN/SIGBED International Conference on Languages, Compilers, and Tools for Embedded Systems (LCTES 2026)",
    publishedBy: { "@type": "Organization", name: "ACM" },
    location: "Boulder, Colorado, United States"
  },
  creativeWorkStatus: "WIP — Accepted",
  url: "https://github.com/SuryanshSS1011/SecureCodeRL/blob/main/paper/lctes26-paper.pdf"
};

const cnsmPaperSchema = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  name: "Match Your Loss to Your Cost: Asymmetric Losses and Conformal Capacity Bands for Backbone Traffic Forecasting",
  author,
  isPartOf: {
    "@type": "PublicationEvent",
    name: "21st International Conference on Network and Service Management (CNSM 2026)"
  },
  creativeWorkStatus: "Submitted",
  dateCreated: "2026-06-01",
  url: "https://github.com/SuryanshSS1011/match-loss-to-cost"
};

const allPaperSchemas = [aiTestPaperSchema, lctesPaperSchema, cnsmPaperSchema];
---

<BaseLayout
  title="Research · Suryansh Sijwali"
  description="Peer-reviewed and WIP research by Suryansh Sijwali. Fixing Performance Bugs Through LLM Explanations (IEEE AITest 2025), Scheduled Partial-Credit RL for Reliable Code Generation with SLMs (LCTES 2026 WIP, Patishnock Award), Match Your Loss to Your Cost: Asymmetric Losses and Conformal Capacity Bands for Backbone Traffic Forecasting (CNSM 2026 submission)."
  jsonLd={allPaperSchemas}
>
  <SectionHeading
    eyebrow="Research"
    title="Papers and ongoing investigations"
    description="Peer-reviewed work, work-in-progress papers, and research-grade builds. Status reflects publication or interim findings."
    level="h1"
  />

  {current.length > 0 && (
    <section>
      <p class="bucket-label">In progress</p>
      <div class="project-list">
        {current.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )}

  {past.length > 0 && (
    <section>
      <p class="bucket-label">Published</p>
      <div class="project-list">
        {past.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
