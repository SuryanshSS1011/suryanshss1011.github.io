---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { projects, site } from '../data/site';

const research = projects.filter(p => p.category === 'research');
const current = research.filter(p => p.current);
const past = research.filter(p => !p.current);

const aiTestPaperSchema = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  name: "Fixing Performance Bugs Through LLM Explanations",
  author: {
    "@type": "Person",
    name: site.name,
    url: site.url
  },
  isPartOf: {
    "@type": "PublicationEvent",
    name: "7th IEEE International Conference on Artificial Intelligence Testing (AITest 2025)",
    publishedBy: { "@type": "Organization", name: "IEEE" }
  },
  datePublished: "2025",
  identifier: "10.1109/AITest66680.2025.00020",
  url: "https://doi.org/10.1109/AITest66680.2025.00020"
};
---

<BaseLayout
  title="Research · Suryansh Sijwali"
  description="Research projects and peer-reviewed papers by Suryansh Sijwali: SecureCodeRL (LCTES 2026 WIP, Patishnock Award), ML for network traffic prediction, and LLM explanations for Java performance bugs (IEEE AITest 2025)."
  jsonLd={aiTestPaperSchema}
>
  <SectionHeading
    eyebrow="Research"
    title="Papers and ongoing investigations"
    description="Peer-reviewed work, work-in-progress papers, and research-grade builds. Status reflects publication or interim findings."
    level="h1"
  />

  {current.length > 0 && (
    <section>
      <h2>Currently working on</h2>
      <div class="project-list">
        {current.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )}

  {past.length > 0 && (
    <section>
      <h2>Selected past work</h2>
      <div class="project-list">
        {past.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
