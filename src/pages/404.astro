---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Suryansh Sijwali" description="The page you're looking for doesn't exist.">
  <section class="profile" style="text-align: center; padding: var(--spacing-xl) 0;">
    <span class="eyebrow">404</span>
    <h1>Page not found</h1>
    <p class="bio">The page you're looking for doesn't exist or has moved. Try one of these instead.</p>
    <div class="links" style="justify-content: center;">
      <a href="/">Home</a>
      <a href="/research">Research</a>
      <a href="/engineering">Engineering</a>
      <a href="/blog">Writing</a>
    </div>
  </section>
</BaseLayout>
